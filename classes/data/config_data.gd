## Contiene la configuración del juego
class_name ConfigData
extends Resource

## Volumen de la música
@export var music = 100.0

## Volumen del sonido
@export var sfx = 100.0

## Brillo de pantalla
@export var bright = 100.0

## Silencio del volumen general
@export var mute = false

## Animaciones activas
@export var animations = true
