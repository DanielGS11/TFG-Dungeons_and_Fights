; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dungeons & Fights"
run/main_scene="uid://b06hdqq1ss0v4"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://emqfhpuaxwtq"

[audio]

buses/default_bus_layout="uid://34n86jvgxyif"

[autoload]

GameAPI="*uid://ng0uoa1ekk7e"
GameManager="*uid://bpi1k0ieneu08"
MusicPlayer="*uid://b4oiinh00vrml"

[display]

window/size/viewport_width=540
window/size/viewport_height=1200
window/size/initial_position_type=0
window/size/borderless=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=5

[file_customization]

folder_colors={
"res://assets/": "orange",
"res://classes/": "blue",
"res://resources/": "purple",
"res://scenes/": "gray",
"res://system/": "green"
}

[gui]

theme/custom_font="uid://dwpytq0i4f7ey"

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
