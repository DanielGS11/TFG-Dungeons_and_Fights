; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dungeons & Fights"
run/main_scene="uid://bplpc1vcpbll6"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://emqfhpuaxwtq"

[autoload]

GameAPI="*uid://ng0uoa1ekk7e"
GameManager="*uid://bpi1k0ieneu08"

[display]

window/size/viewport_width=495
window/size/viewport_height=880
window/size/initial_position_type=0
window/size/borderless=true
window/stretch/aspect="expand"
window/handheld/orientation=5

[file_customization]

folder_colors={
"res://android/": "red",
"res://assets/": "orange",
"res://classes/": "blue",
"res://exports/": "red",
"res://resources/": "purple",
"res://scenes/": "gray",
"res://system_autoloads/": "green"
}

[gui]

theme/custom_font="uid://dwpytq0i4f7ey"

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
